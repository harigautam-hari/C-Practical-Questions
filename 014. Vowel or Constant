#include<stdio.h>
int main(){
    char c;
    printf("Enter your alphabet (use small letters only):- ");
    scanf(" %c", &c);

    if(c >= 'a' && c <= 'z'){
        if(c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u'){
            printf("%c is a Vowel", c);
        }
        else{
            printf("%c is a Consonant", c);
        }
    }
    else{
        printf("Invalid Input");
    }

    return 0;
}
