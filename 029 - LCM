#include<stdio.h>
int main(){
    int a, b, i, start;
    printf("Enter your first number :- ");
    scanf("%d",&a);
	printf("Enter your second number :- ");
	scanf("%d",&b);
    if(a > b){
        start = a;
    } else {
        start = b;
    }
    for(i = start; i <= a * b; i++){
        if(i % a == 0 && i % b == 0){
            printf("LCM = %d", i);
            break;
        }
    }
    return 0;
}
